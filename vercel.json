{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/(css|js|images|uploads)/(.*)", "dest": "/public/$1/$2" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "views/**",
        "routes/**",
        "models/**",
        "public/css/**",
        "public/js/**"
      ],
      "excludeFiles": [
        "public/images/**",
        "public/uploads/**"
      ]
    }
  }
}

